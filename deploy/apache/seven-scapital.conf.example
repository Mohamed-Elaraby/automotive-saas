<VirtualHost *:80>
    ServerName seven-scapital.com
    ServerAlias www.seven-scapital.com *.seven-scapital.com

    RewriteEngine On
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</VirtualHost>

<IfModule mod_ssl.c>
<VirtualHost *:443>
    ServerName seven-scapital.com
    ServerAlias www.seven-scapital.com *.seven-scapital.com

    DocumentRoot /var/www/automotive-saas/public

    # If seven-scapital.com is split between a separate landing app at /
    # and this Laravel workspace app at /workspace or /admin, expose theme
    # assets from the automotive Laravel public directory as /theme.
    #
    # Alias /theme/ /var/www/automotive/public/theme/
    # <Directory /var/www/automotive/public/theme>
    #     Require all granted
    #     Options FollowSymLinks
    # </Directory>

    SSLEngine on
    SSLCertificateFile /etc/letsencrypt/live/seven-scapital.com/fullchain.pem
    SSLCertificateKeyFile /etc/letsencrypt/live/seven-scapital.com/privkey.pem

    <Directory /var/www/automotive-saas/public>
        AllowOverride All
        Require all granted
        Options Indexes FollowSymLinks
        DirectoryIndex index.php
    </Directory>

    ErrorLog ${APACHE_LOG_DIR}/seven-scapital-error.log
    CustomLog ${APACHE_LOG_DIR}/seven-scapital-access.log combined
</VirtualHost>
</IfModule>
