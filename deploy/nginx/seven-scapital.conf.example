server {
    listen 80;
    listen [::]:80;
    server_name seven-scapital.com www.seven-scapital.com *.seven-scapital.com;

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name seven-scapital.com www.seven-scapital.com *.seven-scapital.com;

    root /var/www/automotive-saas/public;
    index index.php index.html;

    ssl_certificate     /etc/letsencrypt/live/seven-scapital.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/seven-scapital.com/privkey.pem;

    add_header X-Frame-Options "SAMEORIGIN";
    add_header X-Content-Type-Options "nosniff";

    charset utf-8;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    # If seven-scapital.com is split between a separate landing app at /
    # and this Laravel workspace app at /workspace or /admin, keep /theme
    # served from the automotive Laravel public directory. The Blade layouts
    # generate URLs like /theme/css/bootstrap.min.css.
    #
    # Example for a split server block whose main root is /var/www/saas/public:
    #
    # location ^~ /theme/ {
    #     alias /var/www/automotive/public/theme/;
    #     try_files $uri =404;
    #     access_log off;
    #     expires 30d;
    #     add_header Cache-Control "public";
    # }
    #
    # location = /theme/img/favicon.png {
    #     alias /var/www/automotive/public/theme/img/favicon.png;
    #     access_log off;
    #     log_not_found off;
    # }

    location = /favicon.ico { access_log off; log_not_found off; }
    location = /robots.txt  { access_log off; log_not_found off; }

    error_page 404 /index.php;

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/run/php/php8.2-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        fastcgi_param DOCUMENT_ROOT $realpath_root;
        fastcgi_read_timeout 300;
    }

    location ~ /\.(?!well-known).* {
        deny all;
    }
}
