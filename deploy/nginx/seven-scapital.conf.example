# Production Nginx split for the three independent Laravel projects.
#
# Live mapping:
# - /etc/nginx/sites-available/saas       => /var/www/saas/public
# - /etc/nginx/sites-available/automotive => /var/www/automotive/public
# - /etc/nginx/sites-available/spareparts => /var/www/spareparts/public
#
# The file name "automotive" is legacy server naming only. It now hosts the
# multi-product system app, not an automotive-only product.

# /etc/nginx/sites-available/saas
server {
    listen 80;
    listen [::]:80;
    server_name seven-scapital.com www.seven-scapital.com;

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name seven-scapital.com www.seven-scapital.com;

    root /var/www/saas/public;
    index index.php index.html;

    ssl_certificate     /etc/letsencrypt/live/seven-scapital.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/seven-scapital.com/privkey.pem;

    add_header X-Frame-Options "SAMEORIGIN";
    add_header X-Content-Type-Options "nosniff";

    charset utf-8;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    # If the saas frontend templates reference /theme/... then deploy those
    # files to /var/www/saas/public/theme. As a temporary bridge only, this
    # vhost can alias the shared system theme:
    #
    # location ^~ /theme/ {
    #     alias /var/www/automotive/public/theme/;
    #     try_files $uri =404;
    #     access_log off;
    #     expires 30d;
    #     add_header Cache-Control "public";
    # }

    location = /favicon.ico { access_log off; log_not_found off; }
    location = /robots.txt  { access_log off; log_not_found off; }

    error_page 404 /index.php;

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/run/php/php8.2-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        fastcgi_param DOCUMENT_ROOT $realpath_root;
        fastcgi_read_timeout 300;
    }

    location ~ /\.(?!well-known).* {
        deny all;
    }
}

# /etc/nginx/sites-available/automotive
# This is the system app vhost. Use the actual system hostname configured in
# DNS. Keep *.seven-scapital.com here only if tenant workspace subdomains are
# served by this app.
server {
    listen 80;
    listen [::]:80;
    server_name system.seven-scapital.com *.seven-scapital.com;

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name system.seven-scapital.com *.seven-scapital.com;

    root /var/www/automotive/public;
    index index.php index.html;

    ssl_certificate     /etc/letsencrypt/live/seven-scapital.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/seven-scapital.com/privkey.pem;

    add_header X-Frame-Options "SAMEORIGIN";
    add_header X-Content-Type-Options "nosniff";

    charset utf-8;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location = /favicon.ico { access_log off; log_not_found off; }
    location = /robots.txt  { access_log off; log_not_found off; }

    error_page 404 /index.php;

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/run/php/php8.2-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        fastcgi_param DOCUMENT_ROOT $realpath_root;
        fastcgi_read_timeout 300;
    }

    location ~ /\.(?!well-known).* {
        deny all;
    }
}

